{
  "manifest_version": 3,
  "name": "Danbooru Saver",
  "version": "0.1.1",
  "description": "Save Danbooru images and matching tag files.",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage",
    "offscreen",
    "debugger"
  ],
  "host_permissions": [
    "https://danbooru.donmai.us/*",
    "https://cdn.donmai.us/*",
    "https://rule34.xxx/*",
    "https://wimg.rule34.xxx/*",
    "https://rule34.us/*",
    "https://gelbooru.com/*",
    "https://*.gelbooru.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://rule34.us/index.php?r=posts/view*"],
      "js": ["src/rule34usWarmCache.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "commands": {
  "save-current-post": {
    "suggested_key": {
      "default": "Alt+Shift+J",
      "mac": "Option+Shift+J"
    },
    "description": "Save current post"
  }
}
}